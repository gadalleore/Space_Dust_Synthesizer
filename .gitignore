# Resource archives (keep .ttf, exclude .zip)
Resources/*.zip
Resources/vcr_extract/

# Claude Code session data
.claude/

# Local helper scripts
copy_vst.ps1
install_vst_admin.bat

# Cursor IDE config
.cursor/

# MCP servers (development tooling)
mcp-servers-jos/

# Installer output (built .pkg, .dmg, .exe) - never commit
installer/Output/

# Inno Setup installer binary staging (dropped here by build script) - never commit.
# Other subfolders of installer/Files/ (e.g. Presets/) ARE tracked because they
# contain factory content that ships with the installer.
installer/Files/VST3/
installer/Files/Standalone/

# macOS installer binary staging area (populated by package-macos.sh - never commit)
installer/macos/payload/
installer/macos/scripts/Presets/
installer/macos/scripts/README.txt

# Scratch files
Untitled

# QA tooling downloads (pluginval is fetched by download-pluginval.ps1)
tools/

# QA monitor outputs (CSV samples, soak baselines, pluginval logs)
runtime-monitor.csv
pluginval-report.log
soak-test-baseline.json

# Crash dumps (configured to land in C:\CrashDumps but ignore if any land here)
CrashDumps/
*.dmp

# Extra build directories and logs
build-safety-rel/
build-asan/
rebuild-safety.log

# Local crash/ASan diagnostic tooling (hardcoded local paths; not for public repo)
build-verify/

# Local preset backup zips (presets themselves are tracked under installer/Files/Presets)
preset-backups/
